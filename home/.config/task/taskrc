# Use the command 'task show' to see all defaults and overrides
editor=nvim
# Files
data.location=/home/trickyni/.task
verbose=no
# To use the default location of the XDG directories,
# move this configuration file from ~/.taskrc to ~/.config/task/taskrc and uncomment below

#data.location=~/.local/share/task
hooks.location=~/.config/task/hooks
include /home/trickyni/.config/task/themes/desert-witch.theme

#   coefficient mods
urgency.tags.coefficient = 0.0
urgency.annotations.coefficient = 0.0
urgency.project.coefficient = 0.0
urgency.age.coefficient = 0.0
urgency.blocked.coefficient = -50.0

# user-defined attributes
uda.priority.values=x,@,o
uda.pipe.type=string
uda.pipe.values=|
uda.pipe.default=|
urgency.uda.priority.o.coefficient=10.0
urgency.uda.priority.x.coefficient=-7.0
urgency.uda.priority.@.coefficient=-15.0

# report default
report.list.columns = id,project,priority,description,urgency,wait.relative
report.list.labels = ID,proj,p,desc,urg,wait
report.list.sort = urgency-
report.list.filter = status:pending or status:waiting 

# report now
report.now.columns = id,project,priority,description,urgency,wait.relative
report.now.labels = ID,proj,p,desc,urg,wait
report.now.sort = urgency-
report.now.filter = status:pending (priority: or priority:o)

# report md
report.md.columns = pipe,priority,pipe,description,pipe,project,pipe,wait.relative,pipe
report.md.labels =,|p,,|desc,,|project,,|wait|, 
report.md.sort = urgency-
report.md.filter = status:pending or status:waiting

# report vim-full
report.vim.columns = priority,description,project
report.vim.labels = ,,
report.vim.sort = urgency-
report.vim.filter = status:pending or status:waiting

# report vim-
report.vim.columns = priority,project,description
report.vim.labels = ,,
report.vim.sort = urgency-
report.vim.filter = status:pending (priority: or priority:o)

#   report unblocked
report.unblocked.columns = id,project,priority,description,tags,due,urgency
report.unblocked.labels = ID,Project,P,Description,Tag,Due,Urg
report.unblocked.sort = urgency-

#  report groups
report.groups.columns=project.indented,id,priority,description.truncated,tags,urgency
report.groups.labels=Project,ID,P,Description,Tag,Urg
report.groups.sort=project+/,urgency-
report.groups.filter=-DELETED -COMPLETED proj.not:
report.groups.description = "Shows only projects, groups by project"

#  report sched
report.due.columns=project.indented,id,depends,priority,description,due.countdown,urgency
report.due.labels=Project,ID,Deps,P,Description,Due,Urg
report.due.sort=due+,urgency-
report.due.filter=status:pending sched.not:
report.due.description = "Timeline view"



include ~/.config/task/twsync
default.command=list
